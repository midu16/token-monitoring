{
  "annotations": {
    "mode": "off"
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "🚀 Token Consumption Overview",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 12, "x": 0, "y": 1 },
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "mode": "drop"
        },
        "textMode": "auto"
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "expr": "sum(llm_tokens_used_total)",
          "format": "timeseries",
          "legendFormat": "Total Tokens",
          "refId": "A"
        }
      ],
      "title": "Total Tokens Used (Lifetime)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 3,
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [
        {
          "expr": "rate(llm_tokens_used_total[5m])",
          "legendFormat": "{{collector}} - {{type}}",
          "refId": "A"
        }
      ],
      "title": "Token Usage Rate (Tokens/sec)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 9 },
      "id": 11,
      "targets": [
        {
          "expr": "rate(llm_nlwp_total[5m])",
          "legendFormat": "{{collector}} - NLWP Rate",
          "refId": "A"
        }
      ],
      "title": "NLWP Usage Rate (Tokens/Weight)",
      "type": "timeseries"
    },
    {
      "gridPos": { "format": "row", "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 4,
      "title": "🐹 Go Runtime Performance",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 10 },
      "id": 5,
      "targets": [
        {
          "expr": "go_goroutines",
          "legendFormat": "Goroutines",
          "refId": "A"
        }
      ],
      "title": "Active Goroutines",
      "type": "gauge"
    },
    {
      "datasource": { "type": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 10 },
      "id": 6,
      "targets": [
        {
          "expr": "rate(go_gc_duration_seconds_sum[5m])",
          "legendFormat": "GC Pause Rate",
          "refId": "A"
        }
      ],
      "title": "GC Pause Duration Rate",
      "type": "timeseries"
    },
    {
      "datasource": { "timestamp_regex": "", "type": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 10 },
      "id": 7,
      "targets": [
        {
          "expr": "go_memstats_heap_alloc_bytes",
          "legendFormat": "Heap Allocated",
          "refId": "A"
        }
      ],
      "title": "Heap Memory Usage",
      "type": "timeseries"
    },
    {
      "gridPos": { "format": "row", "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 8,
      "title": "🖥️ Process & System Health",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 19 },
      "id": 9,
      "targets": [
        {
          "expr": "rate(process_cpu_seconds_total[5m])",
          "legendFormat": "CPU Usage",
          "refId": "A"
        }
      ],
      "title": "CPU Utilization (Seconds/sec)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 19 },
      "id": 10,
      "targets": [
        {
          "expr": "process_resident_memory_bytes",
          "legendFormat": "RSS Memory",
          "refId": "A"
        }
      ],
      "title": "Process Resident Memory",
      "type": "timeseries"
    },
    {
      "gridPos": { "format": "row", "h": 1, "w": 24, "x": 0, "y": 27 },
      "id": 12,
      "title": "🐳 Ollama GPU & Model Metrics",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 28 },
      "id": 13,
      "targets": [
        {
          "expr": "ollama_gpu_utilization_percent",
          "legendFormat": "GPU Util",
          "refId": "A"
        }
      ],
      "title": "GPU Utilization (%)",
      "type": "gauge"
    },
    {
      "datasource": { "type": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 28 },
      "id": 14,
      "targets": [
        {
          "expr": "ollama_gpu_temperature_celsius",
          "legendFormat": "GPU Temp",
          "refId": "A"
        }
      ],
      "title": "GPU Temperature (°C)",
      "type": "gauge"
    },
    {
      "datasource": { "type": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 28 },
      "id": 15,
      "targets": [
        {
          "expr": "(ollama_gpu_vram_used_bytes / ollama_gpu_vram_total_bytes) * 100",
          "legendFormat": "VRAM Usage",
          "refId": "A"
        }
      ],
      "title": "VRAM Utilization (%)",
      "type": "gauge"
    },
    {
      "datasource": { "type": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 28 },
      "id": 16,
      "targets": [
        {
          "expr": "ollama_up",
          "legendFormat": "Status",
          "refId": "A"
        }
      ],
      "title": "Ollama Status",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 36 },
      "id": 17,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(ollama_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p95 Latency",
          "refId": "A"
        }
      ],
      "title": "Request Latency p95 (sec)",
      "type": "timeseries"
    }
  ],
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["token-monitoring", "go"],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "title": "Token Monitoring Dashboard",
